# ── MongoDB Atlas ──────────────────────────────────────────────────────────────
# Create a free cluster at https://cloud.mongodb.com, then get the connection
# string from "Connect → Drivers" and replace <user>/<password>/<cluster>.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Database name (defaults to "pacman" if omitted)
MONGODB_DB=pacman

# ── NextAuth.js ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace_with_a_random_secret_string

# ── Google OAuth (optional — email+password works without it) ──────────────────
# Create OAuth 2.0 credentials at https://console.cloud.google.com
# Authorised redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
